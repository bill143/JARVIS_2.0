# Version control / CI
.git
.github
.gitignore

# Python caches / build artifacts
**/__pycache__
**/*.pyc
**/*.pyo
.pytest_cache
.ruff_cache
.mypy_cache
*.egg-info
dist
build

# Virtualenvs (the image builds its own)
.venv
venv

# Rust build output (rebuilt inside the image; huge otherwise)
rust/target
target

# Node / frontend build caches
node_modules

# Local data, logs, secrets — must never enter the image
.env
.env.*
!.env.example
credentials.toml
*.db
*.sqlite
*.sqlite3
data/
logs/
results/
traces/
vault/

# Tests and docs are not needed at runtime
tests
docs/_build

# Editor / OS cruft
.idea
.vscode
.DS_Store
