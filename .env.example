# ---------------------------------------------------------------------------
# OpenJarvis environment configuration (example)
#
# Copy this file to `.env` and fill in the values you need. `.env` is
# gitignored and loaded automatically on server startup (see
# openjarvis.core.credentials.bootstrap_secrets). Real environment variables
# always take precedence over this file, so it is a safe local/self-hosted
# fallback. Leave anything you don't use blank or commented out.
#
# SECURITY: never commit a filled-in `.env`. Secrets placed here (or set in the
# real environment) are read at runtime instead of being stored in the app
# database or config.toml in plaintext.
# ---------------------------------------------------------------------------

# --- Dashboard / API auth gateway (Stage 1) --------------------------------
# Enable the session-auth gateway and seed the first admin user on first boot.
OPENJARVIS_AUTH_ENABLED=false
OPENJARVIS_ADMIN_USER=
OPENJARVIS_ADMIN_PASSWORD=
# Optional bearer API key for programmatic access (server.auth.api_key).
OPENJARVIS_API_KEY=

# --- Cloud inference providers ---------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
TAVILY_API_KEY=

# --- Messaging channels -----------------------------------------------------
# Slack
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
# Telegram
TELEGRAM_BOT_TOKEN=
# Discord
DISCORD_BOT_TOKEN=
# Email
EMAIL_USERNAME=
EMAIL_PASSWORD=
# WhatsApp
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# BlueBubbles (iMessage)
BLUEBUBBLES_SERVER_URL=
BLUEBUBBLES_PASSWORD=
# SendBlue (iMessage)
SENDBLUE_API_KEY_ID=
SENDBLUE_API_SECRET_KEY=
# LINE
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
# Viber
VIBER_AUTH_TOKEN=
# Messenger
MESSENGER_PAGE_ACCESS_TOKEN=
MESSENGER_VERIFY_TOKEN=
# Reddit
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
# Mastodon
MASTODON_ACCESS_TOKEN=
MASTODON_API_BASE_URL=
# Twitch
TWITCH_TOKEN=
TWITCH_CHANNEL=
# Matrix
MATRIX_HOMESERVER=
MATRIX_ACCESS_TOKEN=
# Mattermost
MATTERMOST_URL=
MATTERMOST_TOKEN=
# Zulip
ZULIP_EMAIL=
ZULIP_API_KEY=
ZULIP_SITE=
# Rocket.Chat
ROCKETCHAT_URL=
ROCKETCHAT_USER_ID=
ROCKETCHAT_AUTH_TOKEN=
# XMPP
XMPP_JID=
XMPP_PASSWORD=
# Feishu / Lark
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# Nostr
NOSTR_PRIVATE_KEY=

# --- Webhook verification secrets ------------------------------------------
TWILIO_AUTH_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# --- Deployment (docker-compose + Caddy reverse proxy) ---------------------
# Public domain Caddy serves and requests a Let's Encrypt cert for. Leave as
# "localhost" for local testing (Caddy uses its own internal CA).
JARVIS_DOMAIN=localhost
# Email for the Let's Encrypt/ACME account (recommended on a real domain).
ACME_EMAIL=
# Host path to the Obsidian vault mounted into the app container at /vault.
VAULT_PATH=./vault
