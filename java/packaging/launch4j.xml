<?xml version="1.0" encoding="UTF-8"?>
<!--
  Launch4j FALLBACK: wraps app/target/jarvis.jar into a single jarvis.exe.

  Use this only if the .msi path (package-windows.ps1 / jpackage) is blocked because the
  WiX Toolset can't be installed on the build machine.

  Honest limitation: unlike the jpackage .msi, this .exe is NOT self-contained. It looks for
  a JRE 21 first in a "runtime" folder next to the exe (drop a jlink/JDK runtime there to
  bundle one), then falls back to a Java 21 installed on the user's machine. If neither is
  present it points the user at the download URL below.

  To add an icon: place an .ico beside this file and add <icon>jarvis.ico</icon> below.
  Build:  launch4jc packaging\launch4j.xml   ->  packaging\dist\jarvis.exe
-->
<launch4jConfig>
  <headerType>gui</headerType>
  <jar>../app/target/jarvis.jar</jar>
  <outfile>dist/jarvis.exe</outfile>
  <errTitle>JARVIS</errTitle>
  <downloadUrl>https://adoptium.net/temurin/releases/?version=21</downloadUrl>
  <cmdLine></cmdLine>
  <chdir>.</chdir>
  <priority>normal</priority>
  <stayAlive>true</stayAlive>
  <restartOnCrash>false</restartOnCrash>
  <jre>
    <path>runtime</path>
    <minVersion>21.0.0</minVersion>
    <requiresJdk>false</requiresJdk>
    <requires64Bit>true</requires64Bit>
  </jre>
  <versionInfo>
    <fileVersion>0.1.0.0</fileVersion>
    <txtFileVersion>0.1.0</txtFileVersion>
    <fileDescription>JARVIS - local AI assistant</fileDescription>
    <copyright>JARVIS Project</copyright>
    <productVersion>0.1.0.0</productVersion>
    <txtProductVersion>0.1.0</txtProductVersion>
    <productName>JARVIS</productName>
    <internalName>jarvis</internalName>
    <originalFilename>jarvis.exe</originalFilename>
  </versionInfo>
</launch4jConfig>
